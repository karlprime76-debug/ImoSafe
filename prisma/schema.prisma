// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

model Stay {
  id                 String                 @id @default(cuid())
  title              String
  description        String
  city               String
  neighborhood       String
  addressApprox      String?
  pricePerNight      Int
  pricePerWeek       Int?
  pricePerMonth      Int?
  cleaningFee        Int?
  deposit            Int?
  maxGuests          Int
  bedrooms           Int
  bathrooms          Int
  amenities          String[]
  availabilityStatus StayAvailabilityStatus @default(AVAILABLE)
  verificationStatus VerificationStatus     @default(NOT_VERIFIED)
  trustScore         Int?
  hostId             String
  host               User                   @relation(fields: [hostId], references: [id], onDelete: Cascade)
  isHidden           Boolean                @default(false)
  checkInTime        String?
  checkOutTime       String?
  rules              String[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  stayImages      StayImage[]
  documents       Document[]
  bookingRequests BookingRequest[]

  @@index([city])
  @@index([verificationStatus])
  @@index([availabilityStatus])
  @@index([hostId])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  alt        String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([sortOrder])
}

model StayImage {
  id        String   @id @default(cuid())
  stayId    String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  stay Stay @relation(fields: [stayId], references: [id], onDelete: Cascade)

  @@index([stayId])
  @@index([sortOrder])
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  OWNER
  AGENCY
  HOST
  ADMIN
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  OFFICE
  SHOP
  WAREHOUSE
}

enum TransactionType {
  RENT
  SALE
}

enum PropertyStatus {
  AVAILABLE
  RESERVED
  RENTED
  SOLD
  HIDDEN
}

enum StayAvailabilityStatus {
  AVAILABLE
  LIMITED
  UNAVAILABLE
}

enum BookingRequestStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum ManualPaymentOffer {
  AGENCE_PRO
  HOST_STAYS_PRO
  PREMIUM_USER
  VERIFICATION
  BOOST_LISTING
}

enum ManualPaymentStatus {
  PENDING
  IN_REVIEW
  ACTIVATED
  REJECTED
}

enum VerificationStatus {
  NOT_VERIFIED
  PENDING
  VERIFIED
  REJECTED
  SUSPICIOUS
}

enum VisitRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
}

enum ScamReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum DocumentType {
  ID
  TITLE_DEED
  SALE_CONVENTION
  LEASE
  RECEIPT
  RENTAL_AUTH
  OWNER_ID
  AGENCY_LICENSE
  OTHER
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  phone        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  propertiesOwned Property[]       @relation("PropertyOwner")
  agencies        Agency[]
  favorites       Favorite[]
  visitRequests   VisitRequest[]
  scamReports     ScamReport[]
  stays           Stay[]
  documents       Document[]
  bookingRequests BookingRequest[]
}

model Agency {
  id                 String             @id @default(cuid())
  name               String
  phone              String?
  email              String?
  address            String?
  verificationStatus VerificationStatus @default(NOT_VERIFIED)
  ownerId            String
  owner              User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt          DateTime           @default(now())

  properties Property[]

  @@index([ownerId])
  @@index([verificationStatus])
}

model Property {
  id                 String             @id @default(cuid())
  title              String
  description        String
  type               PropertyType
  transactionType    TransactionType
  price              Int
  city               String
  neighborhood       String?
  address            String?
  bedrooms           Int?
  bathrooms          Int?
  area               Int?
  contactWhatsApp    String?
  notes              String?
  images             String[]
  status             PropertyStatus     @default(AVAILABLE)
  verificationStatus VerificationStatus @default(NOT_VERIFIED)
  trustScore         Int?
  isHidden           Boolean            @default(false)

  ownerId String?
  owner   User?   @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites      Favorite[]
  visitRequests  VisitRequest[]
  scamReports    ScamReport[]
  documents      Document[]
  propertyImages PropertyImage[]

  @@index([city])
  @@index([type])
  @@index([transactionType])
  @@index([verificationStatus])
  @@index([status])
}

model Favorite {
  id         String @id @default(cuid())
  userId     String
  propertyId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model VisitRequest {
  id            String             @id @default(cuid())
  userId        String
  propertyId    String
  preferredDate DateTime?
  preferredTime String?
  message       String?
  status        VisitRequestStatus @default(PENDING)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([propertyId])
  @@index([status])
}

model ScamReport {
  id             String           @id @default(cuid())
  userId         String?
  propertyId     String?
  reason         String
  description    String?
  phoneOrContact String?
  status         ScamReportStatus @default(OPEN)
  createdAt      DateTime         @default(now())

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model Document {
  id                 String             @id @default(cuid())
  propertyId         String?
  stayId             String?
  type               DocumentType
  fileUrl            String
  fileName           String?
  verificationStatus VerificationStatus @default(PENDING)
  uploadedById       String?
  createdAt          DateTime           @default(now())

  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  stay       Stay?     @relation(fields: [stayId], references: [id], onDelete: Cascade)
  uploadedBy User?     @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([stayId])
  @@index([uploadedById])
  @@index([verificationStatus])
}

model BookingRequest {
  id           String               @id @default(cuid())
  userId       String?
  stayId       String
  checkInDate  DateTime
  checkOutDate DateTime
  guests       Int
  name         String
  whatsapp     String
  message      String?
  status       BookingRequestStatus @default(PENDING)
  createdAt    DateTime             @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  stay Stay  @relation(fields: [stayId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stayId])
  @@index([status])
  @@index([createdAt])
}

model ManualPaymentRequest {
  id        String              @id @default(cuid())
  name      String
  phone     String
  email     String?
  offer     ManualPaymentOffer
  message   String?
  status    ManualPaymentStatus @default(PENDING)
  createdAt DateTime            @default(now())

  @@index([offer])
  @@index([status])
  @@index([createdAt])
}
